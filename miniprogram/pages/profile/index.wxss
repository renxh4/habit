page {
  background-color: #f6f8f7;
}

.profile-page {
  display: flex;
  flex-direction: column;
}

.profile-header {
  padding: 48rpx 0 16rpx;
  display: flex;
  justify-content: center;
}

.profile-header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.profile-main {
  padding: 16rpx 48rpx 192rpx;
  box-sizing: border-box;
}

.profile-login-card {
  margin-top: 80rpx;
  padding: 48rpx 40rpx 64rpx;
  border-radius: 32rpx;
  background-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-login-avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 9999rpx;
  background-color: rgba(73, 223, 128, 0.1);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.profile-login-avatar {
  width: 100%;
  height: 100%;
}

.profile-login-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.profile-login-subtitle {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 32rpx;
}

.profile-login-button {
  width: 100%;
  height: 88rpx;
  border-radius: 9999rpx;
  background-color: #49df80;
  color: #ffffff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.profile-avatar-wrapper {
  width: 192rpx;
  height: 192rpx;
  border-radius: 9999rpx;
  background-color: rgba(73, 223, 128, 0.1);
  border-width: 8rpx;
  border-style: solid;
  border-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  overflow: hidden;
}

.profile-avatar-button {
  padding: 0;
  margin: 0;
  border: none;
  background-color: transparent;
  width: 100%;
  height: 100%;
}

button.profile-avatar-button::after {
  border: none;
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-name-block {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
}

.profile-name-input {
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  border-width: 2rpx;
  border-style: solid;
  border-color: #e2e8f0;
  font-size: 28rpx;
  color: #0f172a;
  text-align: center;
  background-color: #ffffff;
}

.profile-motto {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #64748b;
}

.profile-stats {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.profile-stat-card {
  flex: 1;
  padding: 32rpx 0;
  border-radius: 32rpx;
  background-color: #ffffff;
  border-width: 2rpx;
  border-style: solid;
  border-color: #f1f5f9;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.profile-stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #49df80;
}

.profile-stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.profile-menu {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-menu-item {
  padding: 32rpx 24rpx;
  border-radius: 32rpx;
  background-color: #ffffff;
  border-width: 2rpx;
  border-style: solid;
  border-color: #f1f5f9;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.profile-menu-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.profile-menu-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 9999rpx;
  background-color: rgba(73, 223, 128, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.profile-menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.profile-menu-text {
  font-size: 32rpx;
  color: #0f172a;
}

.profile-menu-arrow {
  width: 24rpx;
  height: 24rpx;
}

.profile-menu-item-danger {
  border-color: #fee2e2;
}

.profile-menu-icon-circle-danger {
  background-color: #fee2e2;
}

.profile-menu-text-danger {
  color: #ef4444;
}
