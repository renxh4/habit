page {
  background-color: #f6f8f7;
}

.calendar-page {
  padding: 64rpx 48rpx 192rpx;
  box-sizing: border-box;
}

.calendar-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.calendar-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.calendar-nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.calendar-nav-icon {
  font-size: 40rpx;
  color: #64748b;
}

.calendar-main {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx 24rpx 40rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 48rpx rgba(15, 23, 42, 0.06);
}

.calendar-week-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.calendar-week-label {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: 14.28%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calendar-day-text {
  width: 64rpx;
  height: 64rpx;
  text-align: center;
  line-height: 64rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.calendar-day-out .calendar-day-text {
  color: #cbd5f5;
}

.calendar-day-has-check .calendar-day-text {
  background-color: rgba(73, 223, 128, 0.12);
  color: #22c55e;
}

.calendar-day-today .calendar-day-text {
  border-width: 2rpx;
  border-style: solid;
  border-color: #22c55e;
}

.calendar-day-selected .calendar-day-text {
  background-color: #22c55e;
  color: #ffffff;
}

.calendar-habits-card {
  margin-top: 32rpx;
  padding: 32rpx 24rpx;
  border-radius: 32rpx;
  background-color: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(15, 23, 42, 0.06);
}

.calendar-habits-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.calendar-habits-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.calendar-habits-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.calendar-habits-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.calendar-habit-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 24rpx;
  min-height: 80rpx;
  border-radius: 24rpx;
}

.calendar-habit-item-on {
  background-color: #ecfdf3;
}

.calendar-habit-item-off {
  background-color: #ffffff;
  border-width: 1rpx;
  border-style: solid;
  border-color: #e2e8f0;
}

.calendar-habit-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.calendar-habit-icon-on {
  background-color: #22c55e;
}

.calendar-habit-icon-off {
  border-width: 4rpx;
  border-style: solid;
  border-color: #e2e8f0;
  box-sizing: border-box;
}

.calendar-habit-icon-check {
  font-size: 20rpx;
  line-height: 32rpx;
  color: #ffffff;
}

.calendar-habit-main {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  transform: translateY(-25rpx);
}

.calendar-habit-name {
  display: block;
  height: 32rpx;
  font-size: 28rpx;
  line-height: 28rpx;
}

.calendar-habit-name-on {
  color: #0f172a;
}

.calendar-habit-name-off {
  color: #0f172a;
}

.calendar-habit-time {
  display: block;
  height: 32rpx;
  font-size: 24rpx;
  line-height: 28rpx;
  color: #94a3b8;
}

.calendar-habits-empty {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}
